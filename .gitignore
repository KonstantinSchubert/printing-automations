# Ignore all PDFs — these are transient print jobs, not source.
*.pdf
*.PDF

# Atomic-write temp files from split-pdf.py
*.part

# Per-job retry counters
*.attempts

# Logs and macOS cruft
watcher.log
airprint-bridge.log
.DS_Store

# But always keep the watch folders themselves (their .gitkeep placeholders)
!.gitkeep
